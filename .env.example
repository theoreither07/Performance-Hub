# =====================================================================
# Personal Dashboard — Environment-Template
# Kopiere diese Datei nach `.env` und trage deine Werte ein.
# (`.env` ist gitignored und wird NIE committet.)
# =====================================================================

# --- Database ---
DATABASE_URL="postgresql://dashboard:dashboard@localhost:5432/dashboard?schema=public"

# --- App-Identitaet (oeffentlich, im Browser sichtbar) ---
# Titel der App + optionaler Anzeigename in Begruessung/Sidebar.
NEXT_PUBLIC_APP_NAME="Personal Dashboard"
NEXT_PUBLIC_USER_NAME=""

# --- Auth ---
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="generate-with-openssl-rand-base64-32"
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Single-User-Setup: dein primaeres Google-Konto (dessen Daten das Dashboard zeigt).
PRIMARY_EMAIL="you@example.com"
# Wer sich einloggen darf (Komma-getrennt). Default = PRIMARY_EMAIL.
ALLOWED_EMAILS="you@example.com"

# --- Google Calendar / Gmail ---
# Ein privates Konto (Source of Truth) + optional ein Business-Konto. Pro Konto ein Refresh-Token.
GOOGLE_PRIVATE_EMAIL="you@example.com"
GOOGLE_PRIVATE_REFRESH_TOKEN=""
GOOGLE_BUSINESS_EMAIL=""
GOOGLE_BUSINESS_REFRESH_TOKEN=""
GOOGLE_PRIMARY_ACCOUNT="private"
# Domains, die als BUSINESS-Kalender gelabelt werden (Komma-getrennt). Leer = Domain von GOOGLE_BUSINESS_EMAIL.
BUSINESS_EMAIL_DOMAINS=""

# --- Weather (Open-Meteo, kein API-Key noetig) ---
WEATHER_LAT="48.2082"
WEATHER_LON="16.3738"
WEATHER_CITY="Vienna"

# --- Garmin (optional, fuer Health-Sync) ---
GARMIN_EMAIL=""
GARMIN_PASSWORD=""

# --- MyFitnessPal (optional, fuer Ernaehrungs-Sync, inoffizielle Scraper-API) ---
# Kein Passwort noetig. MFP_USERNAME (dein MFP-Benutzername, nicht die E-Mail)
# wird als effective_username genutzt, da MFPs eigener Metadata-Endpoint aktuell
# serverseitig fehlschlaegt. Login laeuft ueber Session-Cookies: einmalig via
# Browser-Extension "Get cookies.txt LOCALLY" auf myfitnesspal.com exportieren
# und als mfp-sync/cookies.txt ablegen (siehe mfp-sync/sync.py Docstring).
MFP_USERNAME=""

# --- AI-Coach (optional) ---
# Anthropic Claude (primaer fuer Wochenplanung). Key in der Anthropic Console erstellen.
ANTHROPIC_API_KEY=""
# Optionaler Nvidia-NIM-Fallback (OpenAI-kompatibel).
NVIDIA_API_KEY=""

# --- Web-Push (optional) ---
# VAPID-Keypair erzeugen mit:  npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=""
VAPID_PRIVATE_KEY=""
VAPID_SUBJECT="mailto:admin@example.com"

# --- MCP-Server (optional, fuer Claude Desktop Zugriff) ---
MCP_API_TOKEN=""

# --- Cron-Endpoints (optional) ---
COACH_CRON_TOKEN=""

# --- App ---
NODE_ENV="development"
TZ="Europe/Vienna"
